# ============================================================
# .gitignore — i_m_s (Angular 19 + SSR + Tailwind)
# Production-ready
# ============================================================

# ── Compiled & Build Output ───────────────────────────────────
/dist
/tmp
/out-tsc
/bazel-out

# ── Angular Cache ─────────────────────────────────────────────
/.angular/cache
/.angular/

# ── Node / npm ────────────────────────────────────────────────
node_modules/
/node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json

# ── Environment & Secrets ─────────────────────────────────────
src/environments/*.local.ts
.env
.env.*
!.env.example

# ── Testing & Coverage ────────────────────────────────────────
/coverage
.nyc_output/
karma-results/
/testing/results/

# ── CSS / PostCSS / Sass Tools ────────────────────────────────
.sass-cache/
.postcss-cache/
.tailwind-cache/

# ── IDEs and Editors ──────────────────────────────────────────
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.suo
*.user
*.swp
*.swo
*~

# ── Visual Studio Code ────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/

# ── AI / Dev Tools ────────────────────────────────────────────
.qodo/
.copilot/
.cursor/

# ── Miscellaneous Angular ─────────────────────────────────────
/connect.lock
/libpeerconnection.log
testem.log
/typings

# ── SSR Server Artefacts ──────────────────────────────────────
# (dist/i_m_s/server/ is generated, do not commit)
dist/*/server/

# ── OS / System ───────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log

# ── Markdown Docs (auto-generated / report files) ────────────
*.md
!README.md
!CHANGELOG.md
!CONTRIBUTING.md

# ── Temporary ─────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.temp
